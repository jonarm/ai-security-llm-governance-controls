// KQL: Anomalous Copilot Data Access
// Purpose: Detect unusual volume or pattern of Microsoft 365 Copilot interactions referencing
// sensitive content, correlating Copilot usage events with the audit signal from DLP-AI-003
// (audit-only policy on Confidential - Customer Data content referenced via Copilot).
// Maps to: AIR-002 in governance/ai-risk-register.csv
// Data source: OfficeActivity (Copilot interaction events) joined with DLP audit events

let CopilotEvents = OfficeActivity
| where TimeGenerated > ago(1d)
| where Operation has "Copilot" or RecordType == "CopilotInteraction"
| project TimeGenerated, UserId, Operation, ClientIP;
let DlpAuditEvents = OfficeActivity
| where TimeGenerated > ago(1d)
| where Operation == "DlpRuleMatch"
| where AuditData has "DLP-AI-003"
| project TimeGenerated, UserId, AuditData;
CopilotEvents
| join kind=inner (DlpAuditEvents) on UserId
| where abs(datetime_diff('minute', TimeGenerated, TimeGenerated1)) <= 5
| summarize
    CopilotInteractionsWithSensitiveData = count(),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated1)
    by UserId
| where CopilotInteractionsWithSensitiveData >= 10
| extend AnomalyReason = "Unusually high volume of Copilot interactions referencing Confidential customer data within 24h"
| order by CopilotInteractionsWithSensitiveData desc